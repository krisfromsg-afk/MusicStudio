rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /outputs/{allPaths=**} {
      allow read: if true; // Make outputs public so audio players can stream them
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
