{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the Music Wormhole Studio.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's avatar URL."
        },
        "credits": {
          "type": "number",
          "description": "The user's current Wormhole Credits balance."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of account creation."
        }
      },
      "required": ["email", "credits", "role", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a credit transaction (add/use).",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who made the transaction."
        },
        "amount": {
          "type": "number",
          "description": "The amount of credits added (positive) or used (negative)."
        },
        "type": {
          "type": "string",
          "enum": ["add", "use"],
          "description": "The type of transaction."
        },
        "description": {
          "type": "string",
          "description": "A description of the transaction."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the transaction."
        }
      },
      "required": ["userId", "amount", "type", "description", "createdAt"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global settings configured by the admin.",
      "type": "object",
      "properties": {
        "systemInstruction": {
          "type": "string",
          "description": "System instructions for the Gemini AI."
        }
      },
      "required": ["systemInstruction"]
    },
    "Generation": {
      "title": "Generation",
      "description": "Represents an audio/video generation task.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The ID of the user who created the generation."
        },
        "taskId": {
          "type": "string",
          "description": "The task ID from KIE API."
        },
        "taskType": {
          "type": "string",
          "description": "The type of task (e.g., generateMusic, extendMusic)."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "text", "first", "complete", "failed"],
          "description": "The status of the generation."
        },
        "prompt": {
          "type": "string",
          "description": "The prompt used for generation."
        },
        "lyrics": {
          "type": "string",
          "description": "The generated lyrics."
        },
        "style": {
          "type": "string",
          "description": "The style of the generated music."
        },
        "title": {
          "type": "string",
          "description": "The title of the generated music."
        },
        "audioUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the generated audio."
        },
        "videoUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the generated video."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the generated image."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last update."
        },
        "error": {
          "type": "string",
          "description": "Error message if generation failed."
        }
      },
      "required": ["uid", "taskId", "taskType", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and credit balances."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores the history of credit transactions."
    },
    "/admin/{docId}": {
      "schema": { "$ref": "#/entities/AdminSettings" },
      "description": "Stores global admin settings."
    },
    "/generations/{generationId}": {
      "schema": { "$ref": "#/entities/Generation" },
      "description": "Stores audio/video generation tasks."
    }
  }
}
